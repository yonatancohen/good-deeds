{
  "name": "good-deeds",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "tw:build": "tailwindcss -i global.css -o public/tailwind.css --minify && node scripts/css-to-ts.js",
    "tw:watch": "tailwindcss -i global.css -o public/tailwind.css --watch",
    "build:web": "expo export -p web && node scripts/inject-pwa.js",
    "deploy:web": "vercel",
    "deploy:web:prod": "vercel --prod",
    "deploy:setup": "bash scripts/deploy-setup.sh",
    "deploy:all": "bash scripts/deploy.sh",
    "deploy:all:prod": "bash scripts/deploy.sh --prod",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "eas:update": "eas update --branch preview --message \"$(date +%Y-%m-%d_%H:%M)\"",
    "eas:update:prod": "eas update --branch production --message \"$(date +%Y-%m-%d_%H:%M)\""
  },
  "dependencies": {
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-table": "^8.21.3",
    "@types/papaparse": "^5.5.2",
    "expo": "~54.0.33",
    "expo-constants": "^18.0.13",
    "expo-document-picker": "^14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "^6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "^3.0.9",
    "expo-updates": "29.0.16",
    "i18next": "^26.0.5",
    "lucide-react-native": "^1.8.0",
    "moment": "^2.30.1",
    "nativewind": "^4.2.3",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "sonner-native": "^0.24.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eas-cli": "^19.1.0",
    "typescript": "~5.9.2",
    "vercel": "^54.5.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "@xmldom/xmldom": "^0.9.10",
    "ajv": "^8.18.0",
    "diff": "^8.0.3",
    "minimatch": "^10.2.3",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^8.4.2",
    "postcss": "^8.5.10",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.13",
    "tar": "^7.5.11",
    "undici": "^6.24.0",
    "uuid": "^11.1.1",
    "yaml": "^2.8.3"
  },
  "private": true
}
